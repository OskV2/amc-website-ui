---
const {
  title = "AMC Auto Moto Centrum — Warsztat Samochodowy Zielona Góra",
  description = "Warsztat samochodowy z 25-letnim doświadczeniem w Zielonej Górze. Mechanika, elektryka, diagnostyka i renowacja pojazdów zabytkowych.",
  contact = null,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// JSON-LD Structured Data — AutoRepair / LocalBusiness
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "Auto Moto Centrum",
  "alternateName": "AMC Zielona Góra",
  "url": Astro.site?.toString() || "",
  "telephone": contact?.phone ? `+48${contact.phone.replace(/\s/g, "")}` : undefined,
  "email": contact?.email || undefined,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "ul. Jodłowa 2",
    "addressLocality": "Zielona Góra",
    "postalCode": "65-120",
    "addressCountry": "PL",
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 51.9655,
    "longitude": 15.5247,
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00",
  },
  "description": description,
  "priceRange": "$$",
  "image": new URL("/images/r107.jpg", Astro.site).toString(),
  "areaServed": {
    "@type": "City",
    "name": "Zielona Góra",
  },
  "serviceType": [
    "Naprawa samochodów",
    "Diagnostyka komputerowa",
    "Mechanika pojazdowa",
    "Renowacja pojazdów zabytkowych",
    "Układ hamulcowy",
    "Układ wydechowy",
    "Zawieszenie",
    "Układ elektryczny",
  ],
};

// Usuń undefined pola
const cleanJsonLd = JSON.stringify(jsonLd, (_, v) => v === undefined ? undefined : v);
---

<!doctype html>
<html class="scroll-smooth" lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="Auto Moto Centrum" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={cleanJsonLd} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts: Outfit (headings) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-zinc-950 text-zinc-200 antialiased" style="font-family: 'DM Sans', sans-serif;">
    <slot />
  </body>
</html>