---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

// Pobierz content z kolekcji
const settings = await getEntry("settings", "general");
const servicesData = await getEntry("services", "services");
const restorationData = await getEntry("restoration", "restoration");

// React components (Islands) — ładowane z JS tylko tam gdzie potrzebne
import Navbar from "../components/Navbar.jsx";
import About from "../components/About.jsx";
import Services from "../components/Services.jsx";
import Restoration from "../components/Restoration.jsx";
import SocialMedia from "../components/SocialMedia.jsx";
import Contact from "../components/Contact.jsx";
import Footer from "../components/Footer.jsx";
---

<BaseLayout
  title={settings.data.site_name}
  description={settings.data.tagline}
>
  <Navbar client:load />

  <main class="flex min-h-screen flex-col items-center justify-between">
    <About
      client:load
      yearsOnMarket={settings.data.years_on_market}
    />
    <Services
      client:load
      services={servicesData.data.services}
    />
    <Restoration
      client:load
      data={restorationData.data}
    />
    <SocialMedia client:load />
    <Contact
      client:idle
      settings={settings.data}
    />
  </main>

  <Footer client:visible githubProfile={settings.data.github_profile} />
</BaseLayout>
